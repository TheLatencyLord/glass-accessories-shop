# === SERVER CONFIGURATION ===
PORT=3000
NODE_ENV=development

# === DATABASE ===
# Local MongoDB
MONGO_URI=mongodb://localhost:27017/glass-accessories-shop

# OR Cloud MongoDB Atlas (uncomment and add your connection string)
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/glass-shop

# === JWT & SECURITY ===
JWT_SECRET=your-super-secret-key-change-this-in-production
JWT_EXPIRE=7d

# === ADMIN CREDENTIALS ===
ADMIN_EMAIL=admin@glassshop.com
ADMIN_PASSWORD=Admin@123

# === WHATSAPP CONFIGURATION ===
WHATSAPP_NUMBER=919876543210
WHATSAPP_MESSAGE=Hi! I'm interested in your mobile glass and accessories. Please send me details.

# === BUSINESS INFO ===
BUSINESS_NAME=Glass & Accessories Shop
BUSINESS_PHONE=+919876543210
BUSINESS_EMAIL=info@glassshop.com

# === FRONTEND CONFIGURATION ===
VITE_API_URL=http://localhost:3000
